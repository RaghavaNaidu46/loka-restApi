# ─── Application ────────────────────────────────────────────────
APP_NAME=Loka
APP_ENV=development
DEBUG=true

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://loka:loka_secret@localhost:5432/loka_db
SYNC_DATABASE_URL=postgresql+psycopg2://loka:loka_secret@localhost:5432/loka_db

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ─────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ─────────────────────────────────────────────────────────
OTP_EXPIRE_SECONDS=300
MOCK_OTP=true
MOCK_OTP_CODE=123456

# ─── Aadhaar ─────────────────────────────────────────────────────
MOCK_VERIFICATION=true

# ─── File Storage ────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ─── CORS ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]
