# ─── Application ────────────────────────────────────────────────
APP_NAME=Loka
APP_ENV=development
DEBUG=true

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:Aravind%407729@localhost:5432/loka
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:Aravind%407729@localhost:5432/loka

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
MOCK_REDIS=true

# ─── JWT ─────────────────────────────────────────────────────────
SECRET_KEY=loka-dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ─────────────────────────────────────────────────────────
OTP_EXPIRE_SECONDS=300
MOCK_OTP=false
MOCK_OTP_CODE=123456

# ─── Aadhaar ─────────────────────────────────────────────────────
MOCK_VERIFICATION=true
DEBUG_OCR=true

# ─── File Storage ────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ─── CORS ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ─── SMTP ────────────────────────────────────────────────────────
